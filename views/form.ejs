<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles.css" />
    <title>New Message</title>
  </head>
  <body>
    <div class="page">
      <header class="page-header">
        <h1>New Message</h1>
        <a class="link-chip" href="/">Back to messages</a>
      </header>

      <% if (errors.length > 0) { %>
        <section class="card validation-card" aria-live="polite">
          <h2>Please fix the following</h2>
          <ul class="validation-errors">
            <% for (const error of errors) { %>
              <li><%= error.msg %></li>
            <% } %>
          </ul>
        </section>
      <% } %>

      <form class="card form-card" method="POST" action="/new">
        <label for="author">Author</label>
        <input
          id="author"
          name="author"
          type="text"
          placeholder="Your name"
          value="<%= values.author %>"
          maxlength="<%= limits.authorMaxLength %>"
          required
        />

        <label for="message">Message</label>
        <input
          id="message"
          name="message"
          type="text"
          placeholder="Write a short message"
          value="<%= values.message %>"
          maxlength="<%= limits.messageMaxLength %>"
          required
        />

        <button class="button" type="submit">Post message</button>
      </form>
    </div>
  </body>
</html>
