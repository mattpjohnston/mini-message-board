<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %></title>
  </head>
  <body>
    <div class="page">
      <header class="page-header">
        <h1><%= title %></h1>
        <a class="link-chip" href="/">Back to messages</a>
      </header>

      <article class="card message-card">
        <h2 class="message-author"><%= message.user %></h2>
        <p class="message-text"><%= message.text %></p>
        <p class="message-date"><%= message.added.toLocaleString() %></p>
      </article>
    </div>
  </body>
</html>
